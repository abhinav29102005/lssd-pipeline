APP_NAME=distributed-job-scheduler
LOG_LEVEL=INFO

POSTGRES_DSN=postgresql+psycopg2://scheduler:scheduler@localhost:5432/scheduler_db
REDIS_URL=redis://localhost:6379/0

SCHEDULER_ALGORITHM=least_loaded
SCHEDULE_INTERVAL_SECONDS=0.2

CLUSTER_SIZE=100
SIMULATE_NODES=true

DEFAULT_NODE_CPU=8
DEFAULT_NODE_MEMORY_MB=32768

HEARTBEAT_INTERVAL=2
HEARTBEAT_TIMEOUT=8

MAX_RETRIES=3
BASE_RETRY_DELAY=1.5
JOB_TIMEOUT=120

WORKER_POLL_INTERVAL=0.5
JOB_FAILURE_RATE=0.07
